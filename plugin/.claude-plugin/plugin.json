{
  "name": "continuity",
  "description": "Project-scoped continuity layer for AI coding sessions. Helps preserve job state across Claude conversations via structured resume files.",
  "author": {
    "name": "Lilly Ohr",
    "url": "https://github.com/ljohr/continuity"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.js\""
          }
        ]
      }
    ]
  }
}
